---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>{{ site.url }}/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>{{ site.url }}/om/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  <url>
    <loc>{{ site.url }}/redaksjonelle-retningslinjer/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  <url>
    <loc>{{ site.url }}/kilder/</loc>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  {% for page in collections.skadedyr %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ (page.data.updated or page.data.date) | isoDate }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>
  {% endfor %}
  {% for page in collections.ansvar %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ (page.data.updated or page.data.date) | isoDate }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.85</priority>
  </url>
  {% endfor %}
  {% for page in collections.diagnose %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ (page.data.updated or page.data.date) | isoDate }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.85</priority>
  </url>
  {% endfor %}
  {% for page in collections.guider %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ (page.data.updated or page.data.date) | isoDate }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}
  {% for page in collections.kategorier %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endfor %}
  {% for page in collections.produkter %}
  {% if page.url and not page.data.noindex %}
  <url>
    <loc>{{ site.url }}{{ page.url }}</loc>
    <lastmod>{{ (page.data.updated or page.data.date) | isoDate }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  {% endif %}
  {% endfor %}
</urlset>
