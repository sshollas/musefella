{# Usage: {% set cardPest = pest %} {% include "components/pest-card.njk" %} #}
<a href="/{{ cardPest.slug }}/" class="pest-card">
  <div class="pest-card__img-wrap">
    {% if cardPest.image %}
      <img src="{{ cardPest.image }}" alt="{{ cardPest.name }}" width="400" height="180" loading="lazy">
    {% else %}
      <span class="pest-card__icon">{{ cardPest.icon }}</span>
    {% endif %}
  </div>
  <div class="pest-card__body">
    <div class="pest-card__name">{{ cardPest.name }}</div>
    <p class="pest-card__description">{{ cardPest.shortDescription }}</p>
    {% set badgeClass = "badge--low" %}
    {% if cardPest.dangerLevel == "middels" %}{% set badgeClass = "badge--medium" %}{% endif %}
    {% if cardPest.dangerLevel == "høy" %}{% set badgeClass = "badge--high" %}{% endif %}
    <span class="pest-card__badge {{ badgeClass }}">Farenivå: {{ cardPest.dangerLevel }}</span>
  </div>
</a>
