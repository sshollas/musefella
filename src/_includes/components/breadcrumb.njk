{% if breadcrumb and breadcrumb.length %}
<nav class="breadcrumb" aria-label="Brødsmulesti">
  <ol itemscope itemtype="https://schema.org/BreadcrumbList">
    {% for item in breadcrumb %}
    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
      {% if item.url %}
        <a href="{{ item.url }}" itemprop="item"><span itemprop="name">{{ item.label }}</span></a>
      {% else %}
        <span itemprop="name" aria-current="page">{{ item.label }}</span>
      {% endif %}
      <meta itemprop="position" content="{{ loop.index }}">
    </li>
    {% endfor %}
  </ol>
</nav>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {% for item in breadcrumb %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "name": {{ item.label | jsonString | safe }}{% if item.url %},
      "item": "{{ site.url }}{{ item.url }}"{% endif %}
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}
